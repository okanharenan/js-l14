/*Escreva um algoritmo que leia três valores. A, B, C. E informe se a soma de A + B é maior que C.
*/

const numa = parseFloat(prompt("Digite o valor de A: "))
const numb = parseFloat(prompt("Digite o valor de B: "))
const numc = parseFloat(prompt("Digite o valor de C: "))

if (numa + numb > numc) {
    alert("A soma de A + B é maior que C")
} else {
    alert("A soma de A + B não é maior que C")
}